{
  "name": "mxscript",
  "displayName": "MxScript",
  "description": "Development Utilities for IBM Maximo",
  "version": "1.7.0",
  "engines": {
    "vscode": "^1.110.0"
  },
  "publisher": "Rana",
  "author": {
    "name": "Rana Ahmed Naazir",
    "email": "ahmed.naazer@gmail.com",
    "url": "https://github.com/ahmednrana"
  },
  "keywords": [
    "maximo",
    "ibm",
    "automation",
    "script",
    "xml"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmednrana/mxscript.git"
  },
  "icon": "images/icon.png",
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "npm run build",
    "watch:webviews": "node ./scripts/build-webview.js --watch",
    "watch:all": "npm-run-all -p watch:webviews watch:ts",
    "watch:ts": "tsc -watch -p ./",
    "watch": "npm run watch:all",
    "test": "npm run compile && node ./node_modules/vscode/bin/test",
    "build": "npm run build:webviews && tsc -p ./",
    "clean:webviews": "npx rimraf ./media",
    "build:webviews": "npm run clean:webviews && node ./scripts/build-webview.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "activationEvents": [
    "onCommand:mxscript.upload",
    "onCommand:mxscript.update",
    "onCommand:mxscript.compare",
    "onCommand:mxscript.downloadall",
    "onCommand:mxscript.downloadFromMaximo",
    "onCommand:mxscript.refreshCache",
    "onCommand:mxscript.delete",
    "onCommand:mxscript.manageEnvironments",
    "onView:maximoEnvironments",
    "onCommand:mxscript.downloadallappxml",
    "onCommand:mxscript.fetchLogs",
    "onCommand:mxscript.toolsMenu",
    "onCommand:maximoEnvironments.compareWithEnvironment",
    "onCommand:maximoEnvironments.exportEnvironments",
    "onCommand:maximoEnvironments.importEnvironments",
    "onCommand:mxscript.execute",
    "onCommand:mxscript.testApiConsumer",
    "onCommand:mxscript.openInMaximo",
    "onCommand:mxscript.reupload"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mxscript.testApiConsumer",
        "title": "Test Extension API Consumer Consent Flow",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.openInMaximo",
        "title": "Open in Maximo",
        "category": "Maximo [mxscript]",
        "icon": "$(link-external)"
      },
      {
        "command": "mxscript.execute",
        "title": "Execute script using Script Handler",
        "category": "Maximo [mxscript]",
        "icon": "$(play)"
      },
      {
        "command": "mxscript.upload",
        "title": "Upload to Server",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.update",
        "title": "Download (Update) from Server",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.compare",
        "title": "Compare with current Environment",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.downloadall",
        "title": "Download Script(s) from Server",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.downloadallappxml",
        "title": "Download Application xml(s) from Server",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.downloadallcondition",
        "title": "Download Condition(s) from Server",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.downloadFromMaximo",
        "title": "Download from Server",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.refreshCache",
        "title": "Refresh / reload Maximo Cache",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.fetchLogs",
        "title": "Fetch Logs from Manage",
        "category": "Maximo [mxscript]",
        "icon": "$(output)"
      },
      {
        "command": "mxscript.delete",
        "title": "Delete this file from Server",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "mxscript.toolsMenu",
        "title": "MAS Tools",
        "category": "Maximo [mxscript]",
        "icon": "$(tools)"
      },
      {
        "command": "mxscript.reupload",
        "title": "Delete and Upload to Server",
        "category": "Maximo [mxscript]",
        "icon": "$(sync)"
      },
      {
        "command": "mxscript.manageEnvironments",
        "title": "Manage Environments",
        "category": "Maximo [mxscript]",
        "icon": "$(settings-gear)"
      },
      {
        "command": "maximoEnvironments.refreshEnvironments",
        "title": "Refresh Environments",
        "icon": "$(refresh)",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "maximoEnvironments.addEnvironment",
        "title": "Add Environment",
        "icon": "$(add)",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "maximoEnvironments.editEnvironment",
        "title": "Edit Environment",
        "icon": "$(edit)",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "maximoEnvironments.deleteEnvironment",
        "title": "Delete Environment",
        "icon": "$(trash)",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "maximoEnvironments.setActiveEnvironment",
        "title": "Set as Active Environment",
        "icon": "$(check)",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "maximoEnvironments.compareWithEnvironment",
        "title": "Compare with other Environment",
        "icon": "$(compare-changes)",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "maximoEnvironments.exportEnvironments",
        "title": "Export Environments",
        "icon": "$(cloud-upload)",
        "category": "Maximo [mxscript]"
      },
      {
        "command": "maximoEnvironments.importEnvironments",
        "title": "Import Environments",
        "icon": "$(cloud-download)",
        "category": "Maximo [mxscript]"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Maximo configuration",
      "properties": {
        "mxscript.serverSettings.hostname": {
          "type": "string",
          "description": "Hostname / IP of Maximo (e.g. 10.10.12.12 or www.xyz.com)"
        },
        "mxscript.serverSettings.toolsHostname": {
          "type": "string",
          "description": "Hostname for Tools API (maxinst). Only for MAS environments."
        },
        "mxscript.serverSettings.port": {
          "type": "number",
          "description": "Maximo port"
        },
        "mxscript.authentication.username": {
          "type": "string",
          "default": "maxadmin",
          "description": "Username for Maximo Authentication"
        },
        "mxscript.authentication.password": {
          "type": "string",
          "default": "maxadmin",
          "description": "Password for Maximo Authentication"
        },
        "mxscript.authentication.apikey": {
          "type": "string",
          "description": "API key Maximo Authentication"
        },
        "mxscript.authentication.authenticationType": {
          "type": "string",
          "enum": [
            "internal",
            "ldap",
            "apikey"
          ],
          "enumDescriptions": [
            "Maximo's internal authentication",
            "LDAP based authentication using applciation server",
            "API key"
          ],
          "default": "internal",
          "description": "Type of Authentication"
        },
        "mxscript.serverSettings.objectStructure": {
          "type": "string",
          "default": "MXSCRIPT",
          "description": "Object Structure to be used scripts uploading / downloading"
        },
        "mxscript.appxml.objectStructure": {
          "type": "string",
          "default": "MXL_APPS",
          "description": "Object Structure to be used for App XML uploading / downloading"
        },
        "mxscript.condition.objectStructure": {
          "type": "string",
          "default": "MXL_CONDITION",
          "description": "Object Structure to be used for Condition uploading / downloading"
        },
        "mxscript.serverSettings.httpProtocol": {
          "type": "string",
          "enum": [
            "http",
            "https"
          ],
          "enumDescriptions": [
            "Http",
            "Https Secure Protocol"
          ],
          "default": "http",
          "description": "Http protocol (http or https)"
        },
        "mxscript.scriptSettings.createPythonFileForJythonScripts": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Create Jython script in Maximo even if the file in editor is .py"
        },
        "mxscript.scriptSettings.logLevel": {
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR",
            "FATAL"
          ],
          "enumDescriptions": [
            "Logs messages that are useful in debugging",
            "Logs informational messages",
            "Logs messages indicating harmful situations in functionality",
            "Logs message indicating errors in application functionality",
            "Logs very severe errors messages"
          ],
          "type": "string",
          "description": "The log level tp set with scripts when creating / updating them"
        },
        "mxscript.scriptSettings.ignoresslerrors": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Ignore ssl errors"
        },
        "mxscript.scriptSettings.sslcertificate": {
          "type": "string",
          "markdownDescription": "Use custom SSL certificate"
        },
        "mxscript.logging.level": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error",
            "none"
          ],
          "default": "info",
          "description": "Controls the verbosity of logs in the output console"
        },
        "mxscript.serverSettings.activeEnvironmentName": {
          "type": "string",
          "scope": "window",
          "default": "",
          "description": "The friendly name of the currently active Maximo environment profile"
        },
        "mxscript.appxml.formatOnDownloadAndCompare": {
          "type": "boolean",
          "scope": "window",
          "default": true,
          "description": "Whether to format XML on download and compare"
        },
        "mxscript.statusBar.showFetchLogs": {
          "type": "boolean",
          "default": true,
          "description": "Show the Fetch Logs icon in the status bar"
        },
        "mxscript.statusBar.showDownloadFromMaximo": {
          "type": "boolean",
          "default": true,
          "description": "Show the Download from Maximo icon in the status bar"
        },
        "mxscript.statusBar.showUpload": {
          "type": "boolean",
          "default": true,
          "description": "Show the Upload icon in the status bar"
        },
        "mxscript.statusBar.showDownload": {
          "type": "boolean",
          "default": true,
          "description": "Show the Download icon in the status bar"
        },
        "mxscript.statusBar.showCompare": {
          "type": "boolean",
          "default": true,
          "description": "Show the Compare icon in the status bar"
        },
        "mxscript.statusBar.showExecute": {
          "type": "boolean",
          "default": true,
          "description": "Show the Execute icon in the status bar"
        },
        "mxscript.statusBar.showDelete": {
          "type": "boolean",
          "default": true,
          "description": "Show the Delete icon in the status bar"
        },
        "mxscript.statusBar.showReupload": {
          "type": "boolean",
          "default": false,
          "description": "Show the Delete and Upload icon in the status bar"
        },
        "mxscript.statusBar.showToolsMenu": {
          "type": "boolean",
          "default": true,
          "description": "Show the Tools Menu icon in the status bar"
        },
        "mxscript.statusBar.showManageEnvironments": {
          "type": "boolean",
          "default": true,
          "description": "Show the Manage Environments icon in the status bar"
        },
        "mxscript.statusBar.showOpenInMaximo": {
          "type": "boolean",
          "default": false,
          "description": "Show the Open in Maximo icon in the status bar"
        },
        "mxscript.execution.displayLocation": {
          "type": "string",
          "enum": [
            "newTab",
            "sideView",
            "bottomPanel"
          ],
          "enumDescriptions": [
            "Show execution results in a new focused tab in the active editor group",
            "Show execution results in a read-only editor tab beside the current editor",
            "Show execution results in the Output Channel in the bottom panel"
          ],
          "default": "newTab",
          "description": "Where to display the execution results"
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "maximoEnvironments",
          "name": "Maximo Environments",
          "icon": "$(server-environment)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "maximoEnvironments.refreshEnvironments",
          "when": "view == maximoEnvironments",
          "group": "navigation@1"
        },
        {
          "command": "maximoEnvironments.addEnvironment",
          "when": "view == maximoEnvironments",
          "group": "navigation@2"
        },
        {
          "command": "maximoEnvironments.exportEnvironments",
          "when": "view == maximoEnvironments",
          "group": "navigation@3"
        },
        {
          "command": "maximoEnvironments.importEnvironments",
          "when": "view == maximoEnvironments",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "maximoEnvironments.editEnvironment",
          "when": "view == maximoEnvironments",
          "group": "inline"
        },
        {
          "command": "maximoEnvironments.deleteEnvironment",
          "when": "view == maximoEnvironments",
          "group": "inline"
        },
        {
          "command": "maximoEnvironments.setActiveEnvironment",
          "when": "view == maximoEnvironments && viewItem == environment",
          "group": "inline"
        },
        {
          "command": "mxscript.fetchLogs",
          "when": "view == maximoEnvironments && viewItem == environment",
          "group": "inline@1"
        },
        {
          "command": "mxscript.fetchLogs",
          "when": "view == maximoEnvironments && viewItem == activeEnvironment",
          "group": "inline@1"
        },
        {
          "command": "maximoEnvironments.compareWithEnvironment",
          "when": "view == maximoEnvironments",
          "group": "inline@2"
        },
        {
          "command": "mxscript.openInMaximo",
          "when": "view == maximoEnvironments && (viewItem == environment || viewItem == activeEnvironment)",
          "group": "inline@3"
        }
      ],
      "editor/context": [
        {
          "command": "mxscript.execute",
          "when": "resourceExtname == .py || resourceExtname == .js || resourceExtname == .groovy || resourceExtname == .jy",
          "group": "maximo@2"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/mocha": "^2.2.42",
    "@types/node": "^20.4.1",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "@types/vscode": "^1.110.0",
    "esbuild": "^0.25.9",
    "npm-run-all": "^4.1.5",
    "rimraf": "^3.0.2",
    "tslint": "^5.12.1",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@maximomize/maximo-api-client": "latest",
    "@types/node-fetch": "^2.5.5",
    "@vscode-elements/elements": "^2.3.0",
    "@vscode-elements/react-elements": "^2.3.1",
    "@vscode/codicons": "^0.0.40",
    "detect-browsers": "^6.1.0",
    "node-fetch": "^2.6.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "xml-formatter": "^3.6.2",
    "xml2js": "^0.6.2"
  }
}
